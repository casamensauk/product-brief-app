generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BriefStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  SCOPED
}

model ProjectBrief {
  id               String   @id @default(uuid())
  clientName       String
  projectName      String?
  contactEmail     String?
  shareToken       String   @unique
  status           BriefStatus @default(DRAFT)
  
  stakeholders            Json?
  gatheringMethods        Json?
  categorisedRequirements Json?
  analysisModels          Json?
  documentationData       Json?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
