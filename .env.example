# Postgres connection string (e.g. from Neon). Pooled URL is fine for runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Optional: direct (unpooled) connection used by the Prisma CLI for schema pushes.
# Falls back to DATABASE_URL when unset.
DATABASE_URL_UNPOOLED=""

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Canonical URL of the app (used for auth callbacks, origin checks, email links)
BETTER_AUTH_URL="http://localhost:3000"

# Set to "false" to disable public sign-up (existing users can still sign in).
# Any other value (or unset) leaves sign-up open.
ALLOW_SIGNUP="true"

# Email (Resend) powers the questionnaire invite, submission notifications, and
# password reset. Without a key the app still works — those actions report a
# clear "email isn't configured" state instead of sending.
# Get a key at https://resend.com. EMAIL_FROM must be a verified sender.
RESEND_API_KEY=""
EMAIL_FROM="Discovery Pro <onboarding@resend.dev>"

# OpenRouter powers AI questionnaire suggestions and product-brief generation.
# Create a key at https://openrouter.ai/keys — without it the app still works,
# but the AI features return a clear "not configured" error.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"

# Optional: a throwaway Postgres for the integration tests. When unset, the
# integration suite skips and only unit tests run. NEVER point this at a
# database with real data — the tests write and read freely.
TEST_DATABASE_URL=""
